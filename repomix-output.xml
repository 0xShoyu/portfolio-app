/* src/app/globals.css */
@import "tailwindcss";
@plugin "@tailwindcss/typography";

/* =========================================
   1. MODERN CSS RESET
   Based on Josh W. Comeau's reset principles.
   ========================================= */

/* Use border-box for everything to make sizing predictable */
*, *::before, *::after {
  box-sizing: border-box;
}

/* Ensure full height and smooth scrolling behavior */
html, body {
  min-height: 100%;
  scroll-behavior: smooth;
  overflow-x: clip;
}

/* Treat media as block-level to avoid alignment issues */
img, picture, video, canvas, svg {
  display: block;
  max-width: 100%;
}

/* Inherit fonts for form controls */
input, button, textarea, select {
  font: inherit;
}

/* Prevent text overflow from breaking layouts */
p, h1, h2, h3, h4, h5, h6 {
  overflow-wrap: break-word;
}

/* Create a root stacking context (useful for Next.js/React) */
#root, #__next {
  isolation: isolate;
}

/* =========================================
   2. THEME CONFIGURATION (Tailwind v4)
   ========================================= */
@theme {
  --color-background: #082f49; /* Sky 950 */
  --color-foreground: #f0f9ff; /* Sky 50 */

  --color-primary: #38bdf8;    /* Sky 400 */
  --color-primary-foreground: #082f49; /* Sky 950 */

  --color-card: rgba(12, 74, 110, 0.5); /* Sky 900 (Transparent) */
  --color-card-foreground: #f0f9ff;

  --color-border: rgba(56, 189, 248, 0.2); /* Sky 400 (Low Opacity) */
  --color-muted: #94a3b8; /* Slate 400 */
}

/* =========================================
   3. BASE STYLES
   ========================================= */
body {
  background-color: var(--color-background);
  color: var(--color-foreground);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  line-height: 1.5;
}

/* =========================================
   4. TYPOGRAPHY OVERRIDES (Prose)
   Map Tailwind Typography to our theme variables.
   ========================================= */
.prose {
  --tw-prose-body: var(--color-foreground);
  --tw-prose-headings: var(--color-foreground);
  --tw-prose-lead: var(--color-muted);
  --tw-prose-links: var(--color-primary);
  --tw-prose-bold: var(--color-foreground);
  --tw-prose-counters: var(--color-muted);
  --tw-prose-bullets: var(--color-muted);
  --tw-prose-hr: var(--color-border);
  --tw-prose-quotes: var(--color-foreground);
  --tw-prose-quote-borders: var(--color-border);
  --tw-prose-captions: var(--color-muted);
  --tw-prose-code: var(--color-primary);
  --tw-prose-pre-code: var(--color-foreground);
  --tw-prose-pre-bg: var(--color-card);
  --tw-prose-th-borders: var(--color-border);
  --tw-prose-td-borders: var(--color-border);

  /* Optional: Limit width for better readability */
  max-width: 65ch;
}

/* =========================================
   5. TABLE CUSTOMIZATION (Apple Style)
   ========================================= */
.prose table {
  font-size: 0.875rem; /* text-sm */
  width: 100%;
  border-collapse: separate; 
  border-spacing: 0;
  border: 1px solid var(--color-border);
  border-radius: 0.75rem; /* rounded-xl */
  overflow: hidden;
  margin-top: 2rem;
  margin-bottom: 2rem;
  background-color: var(--color-card);
}

.prose thead {
  background-color: rgba(255, 255, 255, 0.05);
}

.prose thead th {
  padding: 0.75rem 1rem;
  border-bottom: 1px solid var(--color-border);
  font-weight: 600;
  text-align: left;
  color: var(--color-foreground);
}

.prose tbody td {
  padding: 0.75rem 1rem;
  border-bottom: 1px solid var(--color-border);
  color: var(--color-muted);
}

.prose tbody tr:last-child td {
  border-bottom: none;
}

.prose tbody strong {
  color: var(--color-primary); 
  font-weight: 600;
}

/* =========================================
   6. CODE BLOCK STYLING (Rehype Pretty Code)
   让代码块看起来像精致的编辑器窗口
   ========================================= */

.prose pre {
  @apply bg-black/50 backdrop-blur-md border border-white/10 rounded-xl overflow-hidden;
  padding: 1.25rem; /* p-5 */
  margin-top: 2rem;
  margin-bottom: 2rem;
  line-height: 1.7;
}

.prose code {
  @apply font-mono text-sm;
  &::before {
    content: "" !important;
  }
  &::after {
    content: "" !important;
  }
}

.prose :not(pre) > code {
  @apply bg-primary/10 text-primary px-1.5 py-0.5 rounded-md border border-primary/20 text-[0.85em] font-medium;
}

.prose pre > code {
  background-color: transparent !important;
  display: grid; 
}

.prose pre::-webkit-scrollbar {
  height: 8px;
}
.prose pre::-webkit-scrollbar-track {
  background: transparent;
}
.prose pre::-webkit-scrollbar-thumb {
  @apply bg-white/10 rounded-full;
}
.prose pre::-webkit-scrollbar-thumb:hover {
  @apply bg-white/20;
}
